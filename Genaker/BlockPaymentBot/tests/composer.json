{
    "name": "genaker/blockpaymentbot-tests",
    "description": "Standalone tests for BlockPaymentBot",
    "type": "library",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Genaker\\BlockPaymentBot\\Tests\\": ""
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

